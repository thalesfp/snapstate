{
  "name": "@snapstore/core",
  "version": "0.11.0",
  "description": "Core class-based reactive stores for Snapstore: dot-path state, path-aware subscriptions, structural sharing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Thales",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thalesfp/snapstore.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/thalesfp/snapstore#readme",
  "bugs": {
    "url": "https://github.com/thalesfp/snapstore/issues"
  },
  "keywords": [
    "state",
    "reactive",
    "store",
    "subscriptions",
    "path-based"
  ]
}
