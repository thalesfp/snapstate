{
  "name": "@snapstore/form",
  "version": "0.11.0",
  "description": "Zod-powered form stores for Snapstore with validation and submit lifecycle",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Thales",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thalesfp/snapstore.git",
    "directory": "packages/form"
  },
  "homepage": "https://github.com/thalesfp/snapstore#readme",
  "bugs": {
    "url": "https://github.com/thalesfp/snapstore/issues"
  },
  "keywords": [
    "state",
    "react",
    "form",
    "zod",
    "validation"
  ],
  "dependencies": {
    "@snapstore/core": "^0.11.0",
    "@snapstore/react": "^0.11.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "zod": ">=4.0.0"
  }
}
