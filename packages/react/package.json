{
  "name": "@snapstore/react",
  "version": "0.11.0",
  "description": "React integration for Snapstore: connect() and scoped stores",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Thales",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thalesfp/snapstore.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/thalesfp/snapstore#readme",
  "bugs": {
    "url": "https://github.com/thalesfp/snapstore/issues"
  },
  "keywords": [
    "state",
    "react",
    "store",
    "reactive",
    "hooks"
  ],
  "dependencies": {
    "@snapstore/core": "^0.11.0",
    "@snapstore/url": "^0.11.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  }
}
